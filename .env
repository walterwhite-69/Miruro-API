# This is an example .env file.
# Copy this file to .env and fill in the required values.

# API key used to authenticate requests to your API.
# Make sure this key is unique and kept secret.
# It must match the API key in your backend .env file.
# If they don’t match, the frontend won’t be able to authenticate
# and you will receive an "Unauthorized" error.
# Use the same key for YumeAnime or your website.
API_KEY=API_KEY=592b50225dd4d524eec26eb3c1a967615764c3c694d8f1f9e6091d8bc883aca7


# Comma-separated list of allowed origins (CORS).
# These are the URLs that are permitted to access your API.
# This should match the origins used in your frontend or website.
# Example:
# ALLOWED_ORIGINS=https://yume-animez.vercel.app,http://localhost:5000
ALLOWED_ORIGINS=*
